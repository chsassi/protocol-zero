---
// src/components/ui/CookieConsent.astro
---

<div
  class="cookie-consent"
  data-cookie-consent
  role="dialog"
  aria-live="polite"
  aria-label="Cookie disclaimer"
  hidden
>
  <div class="cookie-consent__content">
    <p class="cookie-consent__eyebrow">COOKIES</p>
    <p class="cookie-consent__text">
      We use essential cookies to keep the site running and optional cookies to understand basic traffic.
    </p>
  </div>

  <div class="cookie-consent__actions">
    <button class="cookie-consent__button cookie-consent__button--ghost" data-cookie-reject>
      Reject
    </button>
    <button class="cookie-consent__button" data-cookie-accept>
      Accept
    </button>
  </div>
</div>
